# Copy to .env and fill in values
SECRET_KEY=change-me-in-production
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (or set DATABASE_URL directly)
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_NAME=ragdocs

# Optional: override the full DSN
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Optional LLM integration (leave blank to use extractive-answer fallback)
LLM_API_BASE=
LLM_API_KEY=
LLM_MODEL=

# Chunking (tune for your documents)
CHUNK_SIZE=500
CHUNK_OVERLAP=50
